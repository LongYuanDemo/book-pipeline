import { useState, useRef, useCallback, useMemo } from 'react';
import { ChevronLeft, Check, X, Lightbulb, Sparkles, BookOpen, FlaskConical, AlertCircle, Info, Heart, MessageSquare, List, ChevronDown, ChevronRight } from 'lucide-react';
import { chapterContents, type ContentBlock } from '@book/data/chapterContent.ts';
import { bookData } from '@book/data/bookInfo.ts';
import CanvasChat from '../components/CanvasChat.tsx';

interface Props {
  taskId: string;
  onBack: () => void;
  onNavigateTask?: (taskId: string) => void;
}

const calloutStyles = {
  info: { bg: 'bg-blue-50', border: 'border-blue-200', icon: Info, iconColor: 'text-blue-600', titleColor: 'text-blue-900', bodyColor: 'text-blue-800' },
  tip: { bg: 'bg-emerald-50', border: 'border-emerald-200', icon: Lightbulb, iconColor: 'text-emerald-600', titleColor: 'text-emerald-900', bodyColor: 'text-emerald-800' },
  culture: { bg: 'bg-amber-50', border: 'border-amber-200', icon: Heart, iconColor: 'text-amber-600', titleColor: 'text-amber-900', bodyColor: 'text-amber-800' },
  warning: { bg: 'bg-orange-50', border: 'border-orange-200', icon: AlertCircle, iconColor: 'text-orange-600', titleColor: 'text-orange-900', bodyColor: 'text-orange-800' },
};

export default function ChapterContent({ taskId, onBack, onNavigateTask }: Props) {
  const content = chapterContents[taskId];
  const [quizAnswers, setQuizAnswers] = useState<Record<number, number>>({});
  const [chatOpen, setChatOpen] = useState(false);
  const [selectedText, setSelectedText] = useState('');
  const [toolbarPos, setToolbarPos] = useState<{ x: number; y: number } | null>(null);
  const [activeHeading, setActiveHeading] = useState<string | null>(null);
  const contentRef = useRef<HTMLDivElement>(null);
  const headingRefs = useRef<Record<number, HTMLDivElement | null>>({});

  const keyPoints = useMemo(() => {
    if (!content) return [];
    return content.blocks
      .map((block, idx) => ({ idx, title: block.type === 'heading' ? block.content : null }))
      .filter((b): b is { idx: number; title: string } => b.title !== null);
  }, [content]);

  const nextSection = useMemo(() => {
    const allSubs = bookData.chapters.flatMap((ch) => ch.subSections);
    const idx = allSubs.findIndex((s) => s.id === taskId);
    if (idx === -1 || idx >= allSubs.length - 1) return null;
    const next = allSubs[idx + 1];
    if (!chapterContents[next.id]) return null;
    return next;
  }, [taskId]);

  const scrollToHeading = (idx: number) => {
    const el = headingRefs.current[idx];
    if (el) {
      const top = el.getBoundingClientRect().top + window.scrollY - 70;
      window.scrollTo({ top, behavior: 'smooth' });
      setActiveHeading(content.blocks[idx].content || null);
    }
  };

  if (!content) {
    return (
      <div className="min-h-screen bg-stone-50 flex items-center justify-center">
        <div className="text-center">
          <BookOpen className="w-12 h-12 mx-auto mb-3 text-stone-300" />
          <p className="text-stone-500 mb-2">该任务内容正在制作中</p>
          <button onClick={onBack} className="text-sm text-stone-600 underline">返回目录</button>
        </div>
      </div>
    );
  }

  const handleQuiz = (blockIndex: number, optionIndex: number) => {
    if (quizAnswers[blockIndex] !== undefined) return;
    setQuizAnswers({ ...quizAnswers, [blockIndex]: optionIndex });
  };

  const handleMouseUp = useCallback(() => {
    const selection = window.getSelection();
    if (!selection || selection.isCollapsed) {
      setToolbarPos(null);
      return;
    }
    const text = selection.toString().trim();
    if (text.length < 2) {
      setToolbarPos(null);
      return;
    }

    const range = selection.getRangeAt(0);
    const rect = range.getBoundingClientRect();
    const containerRect = contentRef.current?.getBoundingClientRect();
    if (!containerRect) return;

    if (rect.bottom < containerRect.top || rect.top > containerRect.bottom) {
      setToolbarPos(null);
      return;
    }

    setSelectedText(text);
    setToolbarPos({
      x: rect.left + rect.width / 2,
      y: rect.top - 8,
    });
  }, []);

  const openChat = () => {
    if (!selectedText) return;
    setChatOpen(true);
    setToolbarPos(null);
    window.getSelection()?.removeAllRanges();
  };

  return (
    <div className="min-h-screen bg-stone-50">
      {/* Header */}
      <div className="sticky top-0 z-20 bg-white/95 backdrop-blur border-b border-stone-100">
        <div className="flex items-center gap-3 px-4 h-14">
          <button onClick={onBack} className="p-2 -ml-2 rounded-full active:bg-stone-100">
            <ChevronLeft className="w-5 h-5 text-stone-700" />
          </button>
          <div className="flex-1 min-w-0">
            <p className="text-xs text-stone-400">{content.module}</p>
            <h1 className="text-sm font-semibold text-stone-900 truncate">{content.title}</h1>
          </div>
        </div>
      </div>

      {/* Content */}
      <div
        ref={contentRef}
        className="max-w-2xl mx-auto px-4 py-6 pb-24"
        onMouseUp={handleMouseUp}
        onTouchEnd={handleMouseUp}
      >
        {/* Key points navigation */}
        {keyPoints.length > 0 && (
          <div className="mb-6 -mx-4 px-4">
            <div className="flex items-center gap-1.5 text-xs text-stone-400 mb-2">
              <List size={13} />
              <span>关键点导航</span>
            </div>
            <div className="flex gap-2 overflow-x-auto no-scrollbar pb-1">
              {keyPoints.map((kp) => (
                <button
                  key={kp.idx}
                  onClick={() => scrollToHeading(kp.idx)}
                  className={`shrink-0 text-xs rounded-full px-3 py-1.5 border transition-colors ${
                    activeHeading === kp.title
                      ? 'bg-stone-900 text-stone-50 border-stone-900'
                      : 'bg-white text-stone-600 border-stone-200 active:bg-stone-100'
                  }`}
                >
                  {kp.title}
                </button>
              ))}
            </div>
          </div>
        )}

        {/* Reading hint */}
        <div className="mb-6 flex items-center gap-2 text-xs text-stone-400">
          <MessageSquare size={13} />
          <span>选中任意段落文字，向 AI 提问</span>
        </div>

        {content.blocks.map((block, idx) => (
          <div
            key={idx}
            data-block-index={idx}
            ref={(el) => {
              if (block.type === 'heading') headingRefs.current[idx] = el;
            }}
          >
            <BlockRenderer
              block={block}
              index={idx}
              quizAnswers={quizAnswers}
              onQuiz={handleQuiz}
            />
          </div>
        ))}

        {/* Next section button */}
        {nextSection && onNavigateTask && (
          <button
            onClick={() => {
              onNavigateTask(nextSection.id);
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }}
            className="mt-8 w-full flex items-center justify-between rounded-2xl bg-stone-900 text-stone-50 px-5 py-4 active:scale-[0.98] transition-transform"
          >
            <div className="text-left">
              <p className="text-xs text-stone-400">下一节</p>
              <p className="text-sm font-semibold mt-0.5">{nextSection.title}</p>
            </div>
            <ChevronRight className="w-5 h-5 text-stone-400" />
          </button>
        )}
      </div>

      {/* Text selection toolbar */}
      {toolbarPos && selectedText && (
        <div
          className="fixed z-30"
          style={{
            left: toolbarPos.x,
            top: toolbarPos.y,
            transform: 'translate(-50%, -100%)',
            animation: 'fadeIn 0.15s ease-out',
          }}
        >
          <button
            onClick={openChat}
            className="flex items-center gap-1.5 bg-stone-900 text-stone-50 rounded-xl px-3 py-2 text-sm font-medium shadow-lg active:scale-95 transition-transform"
          >
            <Sparkles size={14} />
            向 AI 提问
          </button>
          <div className="flex justify-center -mt-1">
            <div className="w-2.5 h-2.5 bg-stone-900 rotate-45" />
          </div>
        </div>
      )}

      {/* Canvas Chat Panel */}
      {chatOpen && (
        <CanvasChat
          selectedText={selectedText}
          chapterTitle={content.title}
          onClose={() => setChatOpen(false)}
        />
      )}
    </div>
  );
}

function BriefCard({ brief, colors }: {
  brief: { claim: string; points: string[]; example: string; unaddressed: string };
  colors: { iconColor: string; titleColor: string; bodyColor: string };
}) {
  const [expanded, setExpanded] = useState(false);

  return (
    <div className="mt-3 pt-3 border-t border-current/10">
      {/* Claim */}
      <div className={`flex items-start gap-1.5 mb-2.5`}>
        <ChevronDown
          size={13}
          className={`${colors.iconColor} mt-1 flex-shrink-0 transition-transform ${expanded ? 'rotate-180' : ''}`}
        />
        <p className={`text-sm font-semibold ${colors.titleColor} leading-relaxed`}>
          {brief.claim}
        </p>
      </div>

      {/* Points — always visible */}
      <div className="space-y-1.5 mb-2.5 pl-5">
        {brief.points.map((point, i) => (
          <div key={i} className="flex items-start gap-2">
            <span className={`text-xs ${colors.iconColor} font-bold mt-0.5 flex-shrink-0`}>
              {i + 1}.
            </span>
            <p className={`text-sm ${colors.bodyColor} leading-relaxed`}>{point}</p>
          </div>
        ))}
      </div>

      {/* Example + Unaddressed — collapsible */}
      <div className={`pl-5 overflow-hidden transition-all ${expanded ? 'max-h-60' : 'max-h-0'}`}>
        <div className="mb-2.5">
          <p className={`text-xs font-medium ${colors.iconColor} mb-1`}>例</p>
          <p className={`text-sm ${colors.bodyColor} leading-relaxed italic`}>{brief.example}</p>
        </div>
        <div>
          <p className={`text-xs font-medium ${colors.iconColor} mb-1`}>未涉及</p>
          <p className={`text-sm ${colors.bodyColor} leading-relaxed opacity-70`}>{brief.unaddressed}</p>
        </div>
      </div>

      {/* Toggle */}
      <button
        onClick={() => setExpanded(!expanded)}
        className={`ml-5 text-xs ${colors.iconColor} font-medium mt-1`}
      >
        {expanded ? '收起' : '展开例与未涉及'}
      </button>
    </div>
  );
}

function BlockRenderer({
  block,
  index,
  quizAnswers,
  onQuiz,
}: {
  block: ContentBlock;
  index: number;
  quizAnswers: Record<number, number>;
  onQuiz: (blockIndex: number, optionIndex: number) => void;
}) {
  switch (block.type) {
    case 'heading':
      return (
        <h2 className="text-lg font-bold text-stone-900 mt-8 mb-3 flex items-center gap-2">
          <span className="w-1 h-5 bg-stone-800 rounded-full" />
          {block.content}
        </h2>
      );

    case 'paragraph':
      return (
        <p className="text-sm text-stone-700 leading-7 mb-4 select-text relative group">
          {block.content}
          <span className="absolute -right-1 top-0 opacity-0 group-hover:opacity-100 transition-opacity text-stone-300">
            <MessageSquare size={11} />
          </span>
        </p>
      );

    case 'callout': {
      if (!block.callout) return null;
      const s = calloutStyles[block.callout.variant];
      const Icon = s.icon;
      const hasBrief = !!block.callout.brief;
      return (
        <div className={`my-4 rounded-2xl border ${s.bg} ${s.border} p-4`}>
          <div className="flex items-center gap-2 mb-2">
            <Icon className={`w-4 h-4 ${s.iconColor}`} />
            <span className={`text-sm font-bold ${s.titleColor}`}>{block.callout.title}</span>
            {hasBrief && (
              <span className={`text-xs ${s.iconColor} bg-white/60 rounded-full px-2 py-0.5 ml-auto`}>
                Brief
              </span>
            )}
          </div>
          <p className={`text-sm ${s.bodyColor} leading-relaxed mb-3`}>{block.callout.body}</p>
          {hasBrief && block.callout.brief && (
            <BriefCard brief={block.callout.brief} colors={s} />
          )}
        </div>
      );
    }

    case 'steps':
      return (
        <div className="my-4 space-y-2">
          {block.items?.map((item, i) => (
            <div key={i} className="flex items-start gap-3 bg-white rounded-xl border border-stone-100 p-3">
              <div className="w-6 h-6 rounded-full bg-stone-800 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">
                {i + 1}
              </div>
              <p className="text-sm text-stone-700 leading-relaxed">{item}</p>
            </div>
          ))}
        </div>
      );

    case 'tips':
      return (
        <div className="my-4 rounded-2xl bg-emerald-50 border border-emerald-200 p-4">
          <div className="flex items-center gap-2 mb-3">
            <Lightbulb className="w-4 h-4 text-emerald-600" />
            <span className="text-sm font-bold text-emerald-900">制作要点</span>
          </div>
          <div className="space-y-2">
            {block.items?.map((item, i) => (
              <div key={i} className="flex items-start gap-2">
                <Check className="w-4 h-4 text-emerald-600 flex-shrink-0 mt-0.5" />
                <p className="text-sm text-emerald-800 leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
        </div>
      );

    case 'ingredients': {
      if (!block.ingredients) return null;
      return (
        <div className="my-4 grid grid-cols-2 gap-3">
          <div className="rounded-2xl bg-white border border-stone-200 p-4">
            <p className="text-xs font-bold text-stone-500 mb-2">主配料</p>
            <div className="space-y-1.5">
              {block.ingredients.main.map((item, i) => (
                <p key={i} className="text-sm text-stone-700">{item}</p>
              ))}
            </div>
          </div>
          <div className="rounded-2xl bg-white border border-stone-200 p-4">
            <p className="text-xs font-bold text-stone-500 mb-2">调辅料</p>
            <div className="space-y-1.5">
              {block.ingredients.seasoning.map((item, i) => (
                <p key={i} className="text-sm text-stone-700">{item}</p>
              ))}
            </div>
          </div>
        </div>
      );
    }

    case 'quiz': {
      if (!block.quiz) return null;
      const answered = quizAnswers[index] !== undefined;
      const selected = quizAnswers[index];
      const correct = block.quiz.answer;

      return (
        <div className="my-6 rounded-2xl bg-violet-50 border border-violet-200 p-5">
          <div className="flex items-center gap-2 mb-3">
            <FlaskConical className="w-4 h-4 text-violet-600" />
            <span className="text-sm font-bold text-violet-900">随堂测验</span>
          </div>
          <p className="text-sm font-medium text-stone-800 mb-4">{block.quiz.question}</p>
          <div className="space-y-2">
            {block.quiz.options.map((opt, i) => {
              const isSelected = selected === i;
              const isCorrect = i === correct;
              const showCorrect = answered && isCorrect;
              const showWrong = answered && isSelected && !isCorrect;

              return (
                <button
                  key={i}
                  onClick={() => onQuiz(index, i)}
                  disabled={answered}
                  className={`w-full text-left px-4 py-3 rounded-xl border-2 transition-all flex items-center gap-3 text-sm ${
                    showCorrect
                      ? 'border-emerald-400 bg-emerald-50 text-emerald-900 font-medium'
                      : showWrong
                      ? 'border-red-400 bg-red-50 text-red-900'
                      : 'border-violet-200 bg-white text-stone-700 hover:border-violet-300'
                  } ${answered ? 'cursor-default' : 'active:scale-[0.99]'}`}
                >
                  <div className={`w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 ${
                    showCorrect ? 'bg-emerald-500 text-white' : showWrong ? 'bg-red-500 text-white' : 'bg-violet-100 text-violet-600'
                  }`}>
                    {showCorrect ? <Check className="w-3.5 h-3.5" /> : showWrong ? <X className="w-3.5 h-3.5" /> : String.fromCharCode(65 + i)}
                  </div>
                  {opt}
                </button>
              );
            })}
          </div>
          {answered && (
            <div className="mt-3 flex items-start gap-2">
              <Sparkles className="w-4 h-4 text-violet-600 flex-shrink-0 mt-0.5" />
              <p className="text-sm text-violet-800 leading-relaxed">{block.quiz.explanation}</p>
            </div>
          )}
        </div>
      );
    }

    case 'html':
      return (
        <div
          className="my-4 text-sm text-stone-700 leading-7 select-text relative group [&_table]:w-full [&_table]:border-collapse [&_table]:my-3 [&_th]:border [&_th]:border-stone-300 [&_th]:px-3 [&_th]:py-2 [&_th]:bg-stone-100 [&_th]:font-semibold [&_th]:text-stone-800 [&_td]:border [&_td]:border-stone-200 [&_td]:px-3 [&_td]:py-2 [&_img]:max-w-full [&_img]:h-auto [&_img]:rounded-lg [&_img]:my-2 [&_p]:mb-3 [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:my-2 [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:my-2 [&_li]:mb-1 [&_h1]:text-lg [&_h1]:font-bold [&_h1]:mt-4 [&_h1]:mb-2 [&_h2]:text-base [&_h2]:font-bold [&_h2]:mt-3 [&_h2]:mb-2 [&_h3]:text-sm [&_h3]:font-semibold [&_h3]:mt-2 [&_h3]:mb-1"
          dangerouslySetInnerHTML={{ __html: block.content || '' }}
        />
      );

    default:
      return null;
  }
}
